{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Annotix",
  "version": "2.9.0",
  "identifier": "com.tecmedhub.annotix",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Annotix",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$APPDATA/**",
            "$APPLOCALDATA/**",
            "$APPCONFIG/**",
            "$DOCUMENT/**",
            "$DESKTOP/**",
            "$DOWNLOAD/**",
            "$PICTURE/**",
            "$TEMP/**",
            "/tmp/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "Spanish",
          "French",
          "German",
          "Italian",
          "Japanese",
          "Korean",
          "PortugueseBR",
          "Russian",
          "SimpChinese"
        ],
        "compression": "lzma"
      }
    }
  }
}
